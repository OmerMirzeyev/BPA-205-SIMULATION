
﻿
@model List<Position>

<div>
    <a class="btn btn-primary" asp-controller="Position" asp-action="Create">Add Position</a>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th scope="col">#</th>
                <th scope="col">Name</th>
                <th scope="col">Delete Status</th>
                <th colspan="3" scope="col">Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (Position position in Model)
            {
                <tr>
                    <th scope="row">@position.Id</th>
                    <td>@position.Name</td>
                    @if (!position.IsDeleted)
                    {
                        <td class="text-success">Active</td>
                    }
                    else
                    {
                        <td class="text-danger">Inactive</td>

                    }

                    <td>
                        <a class="btn btn-primary" asp-controller="Position" asp-action="Update" asp-route-id="@position.Id">Update</a>
                    </td>

                    
                    <td>
                        @if (!position.IsDeleted)
                        {
                            <form asp-controller="Position" asp-action="Delete" asp-route-id="@position.Id">
                                <button type="submit" class="btn btn-danger">
                                    Delete
                                </button>

                            </form>
                        }
                        else
                        {
                            <form asp-controller="Position" asp-action="Restore" asp-route-id="@position.Id">
                                <button type="submit" class="btn btn-warning">
                                    Restore
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>