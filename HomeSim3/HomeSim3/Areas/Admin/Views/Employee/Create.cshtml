@using HomeSim3.Areas.Admin.ViewModels.Employee
@model CreateEmployeeVM
<form asp-controller="Employee" asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="form-group">
        <label for="Name">Name</label>
        <input asp-for="@Model.Name" type="text" class="form-control" id="Name" placeholder="Name">
            <span class="text-danger" asp-validation-for="@Model.Name"></span>
        </div>
        <div class="form-group">
            <label for="FullAdress">FullAdress</label>
            <input asp-for="@Model.FullAdress" type="text" class="form-control" id="FullAdress" placeholder="FullAdress">
                <span class="text-danger" asp-validation-for="@Model.FullAdress"></span>
            </div>
            <div class="form-group">
                <label for="Image">Image</label>
                <input asp-for="@Model.ImageFile" type="file" class="form-control" id="Image" placeholder="Image">
                    <span class="text-danger" asp-validation-for="@Model.ImageFile"></span>
                </div>
                <select asp-for="PositionId" aria-label="Default select example">
                    <option disable selected>Select Position</option>
                    @foreach (Position position in ViewBag.Positions)
                    {
                        <option value="@position.Id">@position.Name</option>
                    }
                </select>
                <span class="text-danger" asp-validation-for="@Model.PositionId"></span>
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>