@model Place


<div class="container" style="padding-top:200px;">
	<div>
		<div>
			<text>Name<h2>@Model.Name</h2></text>
			<text>FullAddress<h2>@Model.FullAddress</h2></text>
			<text>City<h2>@Model.City.Name</h2></text>
		</div>
		<img style="width:300px; height:300px" src="~/uploads/places/@Model.ImageURL" />
	</div>
</div>