@using Simulation_2.Areas.Admin.ViewModels.Product
@model CreateProductVM



<form asp-controller="Product" asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="form-group">
        <label for="Title">Title</label>
        <input asp-for="@Model.Title" type="text" class="form-control" id="Title" placeholder="Title">
    </div>
    <div class="form-group">    
        <label for="Description">Description</label>
        <input asp-for="@Model.Description" type="text" class="form-control" id="Description" placeholder="Description">
    </div>
    <div class="form-group">
        <label for="Price">Price</label>
        <input asp-for="@Model.Price" type="number" class="form-control" id="Price" placeholder="Price">
    </div>
    <div class="form-group">
        <label for="Image">Image</label>
        <input asp-for="@Model.ImageFile" type="file" class="form-control" id="Image" placeholder="Image">
    </div>
    <select asp-for="CategoryId" aria-label="Default select example">
        <option disable selected>Select Category</option>
        @foreach(Category category in ViewBag.Categories)
                {
                <option value="@category.Id">@category.CategoryName</option>
                }
    </select>
    <button type="submit" class="btn btn-primary">Submit</button>
</form>